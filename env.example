# ============================================================
# NOVALUX — Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# ============================================================
# SUPABASE
# Get these from: https://supabase.com/dashboard/project/[project]/settings/api
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ============================================================
# ANTHROPIC (Claude API — Landing Page Generator)
# Get from: https://console.anthropic.com/settings/keys
# ============================================================
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ============================================================
# GOOGLE AI (Gemini API — Chatbot)
# Get from: https://aistudio.google.com/app/apikey
# ============================================================
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_GEMINI_KEY_HERE

# ============================================================
# APP CONFIG
# ============================================================
NEXT_PUBLIC_ROOT_DOMAIN=novalux.com
NEXT_PUBLIC_APP_URL=https://novalux.com

# ============================================================
# SUPER ADMIN
# Your email — used to identify the super admin on first setup
# ============================================================
SUPER_ADMIN_EMAIL=your@email.com

# ============================================================
# OPTIONAL: Supabase Storage bucket names
# ============================================================
NEXT_PUBLIC_STORAGE_BUCKET_LOGOS=store-logos
NEXT_PUBLIC_STORAGE_BUCKET_PRODUCTS=product-images
NEXT_PUBLIC_STORAGE_BUCKET_PAYMENTS=payment-proofs
