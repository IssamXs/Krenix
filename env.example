# ============================================================
# KRENIX — Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# ============================================================
# SUPABASE
# Get these from: https://supabase.com/dashboard/project/[project]/settings/api
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ============================================================
# ANTHROPIC (Claude API — Landing Page Generator)
# Get from: https://console.anthropic.com/settings/keys
# ============================================================
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ============================================================
# GOOGLE AI (Gemini API — Chatbot)
# Get from: https://aistudio.google.com/app/apikey
# ============================================================
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_GEMINI_KEY_HERE

# ============================================================
# APP CONFIG
# ============================================================
NEXT_PUBLIC_ROOT_DOMAIN=krenix.store
NEXT_PUBLIC_APP_URL=https://krenix.store

# WhatsApp (format: country code + number, no + or spaces, e.g. 213XXXXXXXXX)
NEXT_PUBLIC_WHATSAPP_NUMBER=213XXXXXXXXX

# ============================================================
# SUPER ADMIN
# Your email — used to identify the super admin on first setup
# ============================================================
SUPER_ADMIN_EMAIL=your@email.com

# ============================================================
# OPTIONAL: Supabase Storage bucket names
# ============================================================
NEXT_PUBLIC_STORAGE_BUCKET_LOGOS=store-logos
NEXT_PUBLIC_STORAGE_BUCKET_PRODUCTS=product-images
NEXT_PUBLIC_STORAGE_BUCKET_PAYMENTS=payment-proofs

# ============================================================
# SECURITY / INFRA SECRETS
# ============================================================
# Courier API token encryption (per-store Yalidine/Wecan keys are encrypted at
# rest with this). Generate once with: openssl rand -base64 32 — never rotate
# without re-encrypting existing rows, or every stored courier key breaks.
TOKEN_ENC_KEY=

# Super-admin 2FA step-up (HMAC secret behind the AAL2 gate + destructive-action
# re-auth cookie). Generate once with: openssl rand -base64 32
SUPERADMIN_STEPUP_SECRET=

# Protects the two Vercel cron endpoints (/api/cron/expire-plans,
# /api/cron/abandoned-cart) from being triggered by anyone but Vercel itself.
CRON_SECRET=

# ============================================================
# SLICKPAY (online CIB / Edahabia payments — auto plan activation + top-ups)
# Get the public key from your SlickPay merchant dashboard (SATIM-approved account).
# ============================================================
SLICKPAY_PUBLIC_KEY=          # merchant public key (Bearer token)
SLICKPAY_ACCOUNT_UUID=        # optional; omit to use your default SlickPay account
SLICKPAY_MODE=sandbox         # sandbox | live
SLICKPAY_WEBHOOK_SIGNATURE=   # any random secret; sent on invoice + verified on webhook

# ============================================================
# TRANSACTIONAL EMAIL (plan-approval / credit-topup notifications)
# resend.com > API Keys. EMAIL_FROM must be on a domain verified in Resend,
# e.g. "Krenix <notifications@krenix.store>".
# ============================================================
RESEND_API_KEY=
EMAIL_FROM=

# ============================================================
# META (Messenger + Instagram chatbot channel) — optional feature.
# Create a Meta app at https://developers.facebook.com — see docs/meta-setup.md
# ============================================================
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=            # any string you choose; entered in the Meta webhook config
NEXT_PUBLIC_META_APP_ID=      # same value as META_APP_ID; used by the Facebook Login button

# ============================================================
# TELEGRAM (admin notifications) — optional feature. Message @BotFather for
# the token, message your bot once then check
# https://api.telegram.org/bot<token>/getUpdates for your numeric chat id.
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
